{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx apps/api-ai/src/main.ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx jest apps/api-ai --runInBand"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.base.json --noEmit"
      }
    }
  },
  "tags": []
}
