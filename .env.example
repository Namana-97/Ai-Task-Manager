# ── FREE TIER SETUP (Gemini + local embeddings) ──────────────────────────
# Get your free Gemini key at: https://aistudio.google.com/app/apikey
LLM_PROVIDER=gemini
LLM_API_KEY=AIzaSyDwfKU7yzzEject1m7NX7gvkA9jP75KBzo
LLM_MODEL=gemini-2.5-flash

# Local embeddings — no key needed
EMBEDDING_PROVIDER=local
# EMBEDDING_API_KEY=AIzaSyDwfKU7yzzEject1m7NX7gvkA9jP75KBzo
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# If you switch an existing pgvector table from OpenAI (1536 dims) to local
# all-MiniLM-L6-v2 (384 dims), run migrations/003_vector_dimension_384.sql first.

# ── PAID SETUP (Anthropic/OpenAI embeddings) ──────────────────────────────
# LLM_PROVIDER=anthropic
# LLM_API_KEY=AIzaSyDwfKU7yzzEject1m7NX7gvkA9jP75KBzo
# LLM_MODEL=claude-sonnet-4-20250514
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=AIzaSyDwfKU7yzzEject1m7NX7gvkA9jP75KBzo
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# Vector Store
VECTOR_STORE=pgvector
VECTOR_STORE_URL=postgresql://dev:dev@localhost:5432/taskdb
CHROMA_URL=http://localhost:8000

# Guardrails
MAX_CHAT_REQUESTS_PER_MINUTE=20
LOG_LLM_INTERACTIONS=true
CANARY_TOKEN=__SYSTEM_BOUNDARY_42__

# Feature Flags
AUTH_STUB=true
ENABLE_STANDUP_CRON=false
ENABLE_SEMANTIC_SEARCH=true
SEED_VECTOR_STORE=true

# Dev
NODE_ENV=development
API_PORT=3333
